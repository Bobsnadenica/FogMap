            "query_depth_limit": 0,
            "resolver_count_limit": 0,
            "schema": "schema { query: Query mutation: Mutation }\n\ntype Query {\n  getSharedViewport(worldId: String, minLat: Float!, maxLat: Float!, minLon: Float!, maxLon: Float!, zoom: Int!): SharedViewportResponse\n  listPendingLandmarks(limit: Int, nextToken: String): PendingLandmarkPage\n  getPendingLandmarkReviewUrl(landmarkId: ID!): ReviewUrlResponse\n  getLandmarkViewUrl(landmarkId: ID!): ReviewUrlResponse\n  getMyDiscoveryBootstrap: MyDiscoveryBootstrap!\n}\n\ntype Mutation {\n  syncDiscoveries(worldId: String, cellsJson: AWSJSON!, currentLat: Float, currentLon: Float, mapZoom: Int, displayName: String): DiscoverySyncResponse\n  createLandmarkUploadTicket(worldId: String, title: String!, description: String, category: String!, lat: Float!, lon: Float!, filename: String!, contentType: String!, byteLength: Int!, mapZoom: Int): LandmarkUploadTicket\n  finalizeLandmarkUpload(landmarkId: ID!, uploadToken: String!): LandmarkSubmissionResult\n  moderateLandmark(landmarkId: ID!, approve: Boolean!, moderationNotes: String): LandmarkModerationResult\n}\n\ntype SharedViewportResponse { worldId: String!, cells: [SharedCell!]!, players: [SharedPlayer!]!, landmarks: [SharedLandmark!]!, generatedAt: AWSDateTime! }\ntype SharedCell { cellId: ID!, lat: Float!, lon: Float!, discovererCount: Int!, tileId: String!, lastDiscoveredAt: AWSDateTime! }\ntype SharedPlayer { userId: ID!, displayName: String!, lat: Float!, lon: Float!, lastSeenAt: AWSDateTime! }\ntype SharedLandmark { landmarkId: ID!, title: String!, description: String, category: String!, lat: Float!, lon: Float!, status: String!, approvedObjectKey: String, createdAt: AWSDateTime! }\ntype DiscoverySyncResponse { acceptedCellCount: Int!, newPersonalCellCount: Int!, updatedSharedCellCount: Int!, trackingActive: Boolean!, timestamp: AWSDateTime! }\ntype LandmarkUploadTicket { landmarkId: ID!, uploadToken: String!, objectKey: String!, uploadUrl: AWSURL!, uploadFieldsJson: AWSJSON!, expiresAt: AWSDateTime!, maxBytes: Int! }\ntype LandmarkSubmissionResult { landmarkId: ID!, status: String!, message: String! }\ntype LandmarkModerationResult { landmarkId: ID!, status: String!, approvedObjectKey: String }\ntype ReviewUrlResponse { landmarkId: ID!, viewUrl: AWSURL!, expiresAt: AWSDateTime! }\ntype PendingLandmarkPage { items: [PendingLandmark!]!, nextToken: String }\ntype PendingLandmark { landmarkId: ID!, title: String!, description: String, category: String!, lat: Float!, lon: Float!, status: String!, pendingObjectKey: String!, createdAt: AWSDateTime!, userId: ID! }\ntype MyDiscoveryBootstrap { cells: [MyDiscoveryCell!]! }\ntype MyDiscoveryCell { cellId: String!, lat: Float!, lon: Float! }\nscalar AWSDateTime\nscalar AWSJSON\nscalar AWSURL\n",
            "tags": {
              "Environment": "prod",
              "ManagedBy": "terraform",
              "Project": "world-of-fog"
