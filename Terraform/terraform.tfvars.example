project_name  = "world-of-fog"
environment   = "prod"
aws_region    = "eu-west-2"
max_landmark_upload_bytes          = 5242880
max_pending_landmarks_per_user     = 10
max_landmark_uploads_per_day       = 20
presence_ttl_seconds               = 300
presigned_upload_expiration_seconds = 600
cognito_admin_group_name     = "admin"
cognito_moderator_group_name = "moderator"
cognito_user_group_name      = "user"
cognito_callback_urls = []
cognito_logout_urls   = []
cors_allowed_origins = ["*"]
